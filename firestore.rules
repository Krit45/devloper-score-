rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reports
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the user who saved the report.
    //   - username: string (required) - The GitHub username analyzed.
    //   - score: number (required) - The calculated DevScore.
    //   - stats: map (required) - Detailed analysis statistics.
    //   - profile: map (required) - GitHub profile information.
    //   - createdAt: timestamp (required) - When the report was saved.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kritagyagupta48@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'username', 'score', 'stats', 'profile', 'createdAt']) &&
             data.userId is string &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.stats is map &&
             data.profile is map &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /reports/{reportId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId) && isValidReport(request.resource.data);
      allow update, delete: if isAdmin(); // Users shouldn't need to update or delete their reports for now
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
